# ─── API URL ───
# Development: leave empty to use Vite dev proxy (localhost:5173 → localhost:3000)
#   VITE_API_URL=http://localhost:3000
# Production: set to your Render backend URL
#   VITE_API_URL=https://mybuddy-api.onrender.com
VITE_API_URL=http://localhost:3000

# ─── Sentry (optional error monitoring) ───
# Empty VITE_SENTRY_DSN disables the SDK (no-op).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
