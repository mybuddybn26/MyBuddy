# ─── Faster-Whisper STT Configuration ───

# Model size: tiny, base, small, medium, large-v3
# base = fastest, least accurate | large-v3 = slowest, most accurate
WHISPER_MODEL=base

# Device: cpu or cuda (requires NVIDIA GPU + CUDA toolkit)
WHISPER_DEVICE=cpu

# Compute type: float32, float16, int8
# int8 = fastest on CPU | float32 = most compatible
WHISPER_COMPUTE_TYPE=float32

# Port the service listens on
WHISPER_PORT=8002

# Max upload file size in MB
WHISPER_MAX_FILE_SIZE_MB=25
