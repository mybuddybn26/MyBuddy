DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastify_template?schema=public"

# 48+ byte secret for JWT signing/verification.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=<generate-with-above-command>

# Comma-separated allowed origins for CORS. No default — set explicitly per environment.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173

# 32-byte base64 key.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRED_ENCRYPTION_KEY=<generate-with-above-command>

# Set to true only where the OpenAPI docs UI at /docs should be reachable.
EXPOSE_API_DOCS=false

# ─── AI Provider Keys ───
# Get your key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# Get your key at https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=
# Get your key at https://console.deepgram.com
DEEPGRAM_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ─── DeepSeek Configuration ───
DEEPSEEK_MODEL=deepseek-chat

# ─── Kokoro TTS ───
KOKORO_TTS_URL=http://127.0.0.1:8001

# ─── Faster-Whisper STT (self-hosted) ───
WHISPER_STT_URL=http://127.0.0.1:8002

# ─── Ollama Configuration ───
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:latest

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── File Uploads ───
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
