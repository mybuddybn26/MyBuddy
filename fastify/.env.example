# ─── Required ───
# Neon PostgreSQL connection string (includes sslmode=require)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# 48+ byte secret for JWT signing/verification.
# Generate: openssl rand -base64 48
JWT_SECRET=<generate-with-above-command>

# ─── Production ───
NODE_ENV=production
LOG_LEVEL=info
LOG_PRETTY=false

# Comma-separated allowed origins for CORS.
# Development: http://localhost:5173
# Production: your Render frontend URL (e.g. https://mybuddy.onrender.com)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173

# 32-byte base64 key for credential encryption.
# Generate: openssl rand -base64 32
CRED_ENCRYPTION_KEY=<generate-with-above-command>

# Set to true only where the OpenAPI docs UI at /docs should be reachable.
EXPOSE_API_DOCS=false

# ─── AI Provider Keys ───
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# AssemblyAI (STT): https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=
# Deepgram (TTS): https://console.deepgram.com
DEEPGRAM_API_KEY=
# Groq (STT fallback): https://console.groq.com
GROQ_API_KEY=
ANTHROPIC_API_KEY=
# OpenAI: https://platform.openai.com/api-keys
# Required for Brunei Malay dialect mode (primary provider when dialect=brunei)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# ElevenLabs (TTS deprecated — use Deepgram): https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ─── DeepSeek Configuration ───
DEEPSEEK_MODEL=deepseek-chat

# ─── Kokoro TTS (self-hosted, optional) ───
KOKORO_TTS_URL=http://127.0.0.1:8001

# ─── Faster-Whisper STT (self-hosted, optional) ───
WHISPER_STT_URL=http://127.0.0.1:8002

# ─── Ollama (local AI fallback, optional) ───
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:latest

# ─── Stripe (payments) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── File Uploads ───
# Render: ephemeral filesystem — uploads lost on restart. Use Cloudinary for production.
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Cloudinary (production document storage) ───
# Free tier: https://cloudinary.com — 25 GB storage, 25 GB bandwidth/month
# Get credentials from Cloudinary Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Render-Specific ───
# Render sets PORT automatically — do NOT set PORT here.
# Render sets DATABASE_URL if using Render PostgreSQL.
# HOST is 0.0.0.0 by default (configurable via env if needed).
